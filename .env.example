# ─── GCP Configuration ────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
GCP_SERVICE_NAME=ticket-tagger
ARTIFACT_REGISTRY_REPO=ticket-support-repo

# ─── App Configuration ────────────────────────────────────────────
APP_PORT=8080
APP_ENV=production  # development | production

# ─── Kaggle API (for dataset download) ────────────────────────────
# Get your API credentials from: https://www.kaggle.com/account
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ─── Model Configuration ──────────────────────────────────────────
MODEL_PATH=models/model.pkl
DATA_RAW_PATH=data/raw/customer_support_tickets.csv
DATA_PROCESSED_PATH=data/processed/tickets_clean.csv
